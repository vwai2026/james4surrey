{
  "buildCommand": "",
  "outputDirectory": ".",
  "regions": ["iad1"],
  "functions": {
    "api/*.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
